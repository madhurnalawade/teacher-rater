APP_NAME=Teacher Rating
DEBUG=true
SECRET_KEY=replace-me-with-a-long-random-value

# SQLite for local quick start.
DATABASE_URL=sqlite:///./teacher_rating.db

# PostgreSQL example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/teacher_rating

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Configure the single admin account (recommended: email).
ADMIN_EMAIL=
# Optional alternative to identify admin by Google subject value.
ADMIN_GOOGLE_SUB=

# Keep this value unless you know you need to change it.
GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
FRONTEND_ORIGIN=http://localhost:8000
